# ===== การตั้งค่าอีเมล (ส่งผ่าน Brevo API ทาง HTTPS) =====
# สมัครฟรีที่ https://www.brevo.com แล้วสร้าง API key (SMTP & API > API Keys)
BREVO_API_KEY=your-brevo-api-key-here

# อีเมลผู้ส่ง (ต้องยืนยัน sender นี้ใน Brevo ก่อน) — เช่น Gmail ของร้าน
SENDER_EMAIL=your-shop@gmail.com

# อีเมลร้าน (เจ้าของร้านจะได้รับคำเชิญและสลิปทุกครั้งที่มีการจอง)
OWNER_EMAIL=patiphan.tan@gmail.com

# ชื่อผู้ส่งที่แสดงในอีเมล
MAIL_FROM_NAME=24Lash Studio

# ===== ข้อมูลร้าน =====
SHOP_NAME=24Lash Studio
SHOP_ADDRESS=กรุณาระบุที่อยู่ร้านของคุณ
SHOP_PHONE=08X-XXX-XXXX

# ===== ข้อมูลการโอนมัดจำ =====
DEPOSIT_AMOUNT=300
BANK_NAME=ธนาคารกสิกรไทย
BANK_ACCOUNT_NAME=ชื่อบัญชีของร้าน
BANK_ACCOUNT_NUMBER=XXX-X-XXXXX-X
PROMPTPAY_ID=08X-XXX-XXXX

# พอร์ตเซิร์ฟเวอร์
PORT=3000

# โซนเวลา
TIMEZONE=Asia/Bangkok
